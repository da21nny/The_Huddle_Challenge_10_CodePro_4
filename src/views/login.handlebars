<div class="container">
    <h1>Login</h1>
    
    <script>
        const urlParams = new URLSearchParams(window.location.search);
        if(urlParams.has('registered')) {
            document.write('<p class="success">Cuenta creada exitosamente. Inicia sesión.</p>');
        }
    </script>

    <form action="/auth/login" method="POST">
        <input type="hidden" name="_csrf" value="{{csrfToken}}">
        
        <div class="form-group">
            <label for="email">Correo Electrónico</label>
            <input type="email" id="email" name="email" required>
        </div>
        
        <div class="form-group">
            <label for="password">Contraseña</label>
            <input type="password" id="password" name="password" required>
        </div>

        <div class="form-group">
            <label>Tipo de Sesión:</label>
            <label style="font-weight: normal;"><input type="radio" name="sessionType" value="cookie" checked> Persistente (Cookie)</label>
            <label style="font-weight: normal;"><input type="radio" name="sessionType" value="jwt"> Sin estado (JWT)</label>
        </div>

        <button type="submit">Entrar</button>
        
        <div class="links">
            <a href="/register">¿No tienes cuenta? Regístrate</a>
        </div>
    </form>
</div>
